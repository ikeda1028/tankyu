# Wakuwaku Quest public deployment settings
#
# Copy these names into Vercel:
# Project > Settings > Environment Variables

# Browser-visible Google Maps key. Restrict it by HTTP referrer in Google Cloud.
GOOGLE_MAPS_API_KEY=

# Optional Google Apps Script Web App URL for the Google Drive / Sheets prototype.
GOOGLE_DRIVE_API_URL=

# Admin users who can delete quest points. Comma-separated.
ADMIN_EMAILS=ikeda@manabinomichi.com

# OpenAI keys stay server-side on Vercel. Never expose this in public-config.js.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-2

# Easiest Firebase option: paste the Firebase Web config JSON as one line.
# Example:
# FIREBASE_CONFIG_JSON={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
FIREBASE_CONFIG_JSON=

# Or use individual Firebase fields instead of FIREBASE_CONFIG_JSON.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
